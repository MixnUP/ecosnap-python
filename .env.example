# Required: Firebase Service Account (choose one method)
# 
# Option 1 (Recommended for deployment): Base64 encoded JSON
# 1. Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# 2. Encode: cat service-account.json | base64 | pbcopy (Mac) or base64 -w 0 (Linux)
# 3. Paste the output below
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json-here
#
# Option 2 (Local development): Path to JSON file
# FIREBASE_SERVICE_ACCOUNT=./path/to/service-account.json
#
# Option 3: Use GOOGLE_APPLICATION_CREDENTIALS env var instead

# Required: AI API Key for recipe generation (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Required: API Security (generate a secure random key for backend authentication)
API_SECRET=your_secure_random_key_here

# Optional: CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.vercel.app

# Development
PYTHON_VERSION=3.11.0
